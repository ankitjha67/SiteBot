# Copy to .env and fill in. Do not commit .env.

# Database (pgvector required). The docker-compose default is below.
DATABASE_URL=postgresql://sitebot:sitebot@localhost:5432/sitebot

# Redis: job queue, shared rate limiting, scheduled re-crawls.
# Leave empty for single-process dev mode (in-memory fallbacks).
REDIS_URL=redis://localhost:6379/0

# Global admin key that protects tenant creation and cross-tenant ops. Rotate this.
ADMIN_API_KEY=change-me-admin-key

# Answer generation. Provider is "anthropic" (default), "openai", "gemini",
# or "openai_compatible" (Ollama, Groq, Together, Mistral, vLLM, LM Studio...).
# ANSWER_MODEL must be a model the chosen provider serves.
ANSWER_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANSWER_MODEL=claude-haiku-4-5
ANSWER_MAX_TOKENS=700

# Only if ANSWER_PROVIDER=gemini (pip install ".[gemini]"):
GEMINI_API_KEY=
# Only if ANSWER_PROVIDER=openai_compatible:
# OPENAI_COMPATIBLE_BASE_URL=http://localhost:11434/v1   (Ollama example; ANSWER_MODEL=llama3.1)
# OPENAI_COMPATIBLE_API_KEY=
# Note: ANSWER_PROVIDER=openai reuses OPENAI_API_KEY below.

# Embeddings. Provider is "openai" (default) or "local".
EMBED_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small
EMBED_DIM=1536
# For local embeddings install the extra:  pip install ".[local]"
# LOCAL_EMBED_MODEL=BAAI/bge-small-en-v1.5   (remember EMBED_DIM=384 and update schema)

# Crawler
MAX_PAGES=200
CRAWL_DELAY_S=0.3
USE_BROWSER=false

# Answer cache TTL in seconds (0 disables). Repeat questions cost nothing.
ANSWER_CACHE_TTL_S=86400

# Rate limit per public key + IP, requests per minute.
RATE_LIMIT_PER_MINUTE=30

# Optional: override monthly plan quotas, JSON. 0 = unlimited.
# PLAN_QUOTAS_JSON={"free":100,"starter":2000,"growth":10000,"business":40000}

# Serving. Lock CORS to your customers' domains in production.
CORS_ORIGINS=*

# Public HTTPS base URL of this API (for channel webhooks, e.g. Telegram/WhatsApp).
# PUBLIC_BASE_URL=https://api.yourdomain.com

# Email (SMTP) relay for lead/handoff alerts and digests. Empty host = disabled.
# Each site sets its own recipient address in the dashboard.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=SiteBot <bot@example.com>
SMTP_USE_TLS=true

# Observability
LOG_JSON=true
LOG_LEVEL=INFO
SENTRY_DSN=

# Billing (Phase 3, optional). pip install ".[billing]"
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_MAP_JSON={"price_xxx":"starter","price_yyy":"growth"}
